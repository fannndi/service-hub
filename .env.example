# Database (Supabase PostgreSQL)
# Cara dapetin connection string:
# 1. Buka https://supabase.com/dashboard/project/eboplbemgtvmviwhdlfa/settings/database
# 2. Scroll ke "Connection string" section
# 3. Pilih "URI" mode, copy connection string
# 4. Ganti [YOUR-PASSWORD] dengan password database (lihat di "Database password")
# 5. PASTIKAN pake port 6543 (PgBouncer) biar Prisma gak overload koneksi
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=3

# Redis (Optional — di-skip dulu kalo pake Supabase)
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT Customer
JWT_ACCESS_SECRET=<generate-64-byte-hex>
JWT_REFRESH_SECRET=<generate-64-byte-hex-different>
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# JWT Store Admin
JWT_STORE_ACCESS_SECRET=<generate-64-byte-hex>
JWT_STORE_REFRESH_SECRET=<generate-64-byte-hex-different>

# JWT Platform Admin
JWT_PLATFORM_ADMIN_SECRET=<generate-64-byte-hex>

# Encryption credential
CREDENTIAL_ENCRYPTION_KEY=<generate-32-byte-hex>

# Platform Admin
PLATFORM_ADMIN_PASSWORD=admin

# WhatsApp Fonnte
WA_GATEWAY_URL=https://api.fonnte.com/send
WA_GATEWAY_TOKEN=your-fonnte-token
WA_SENDER_NUMBER=628XXXXXXXXXX

# SMTP (Email fallback when WA fails)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password
SMTP_FROM=noreply@servisgadget.com
STORE_EMAIL=store@servisgadget.com

# Cloudflare R2 (Optional)
STORAGE_ENDPOINT=https://<account-id>.r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=your-r2-access-key
STORAGE_SECRET_KEY=your-r2-secret-key
STORAGE_BUCKET=servisgadget-prod
STORAGE_PUBLIC_URL=https://files.servisgadget.id

# App
APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# SLA (minutes)
SLA_RECEIVE_DEVICE_MINUTES=1440
SLA_DIAGNOSIS_MINUTES=1440
SLA_APPROVAL_MINUTES=1440
SLA_PAYMENT_MINUTES=2880
SLA_CREDENTIAL_CLEAR_MINUTES=1440
SLA_DISPUTE_RESPOND_MINUTES=1440

# Rate limit
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100
