# =============================================
# ServisGadget - Supabase Environment Variables
# =============================================
# Service-hub is 100% serverless - only Supabase needed.
# No NestJS, no Docker, no Redis.
# =============================================

# ─── SUPABASE ───
SUPABASE_URL=https://eboplbemgtvmviwhdlfa.supabase.co
SUPABASE_ANON_KEY=sb_publishable_xxxx

# ─── MIDTRANS (via Supabase Edge Functions) ───
MIDTRANS_SERVER_KEY=Mid-server-xxx
MIDTRANS_CLIENT_KEY=Mid-client-xxx

# ─── WHATSAPP (via Supabase Edge Functions) ───
WA_GATEWAY_URL=https://your-wa-gateway.com
WA_GATEWAY_TOKEN=your-token
WA_SENDER_NUMBER=6281234567890

# ─── FONTTE ───
FONT_TYPE=primary

# ─── BUILD ───
flutter build apk --release \
  --dart-define=SUPABASE_URL=$SUPABASE_URL \
  --dart-define=SUPABASE_ANON_KEY=$SUPABASE_ANON_KEY
