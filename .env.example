# =============================================
# ServisGadget — Environment Variables Reference
# =============================================
# File ini adalah TEMPLATE — tidak dipakai langsung.
# Gunakan secrets/.env.local atau secrets/.env.production.
#
# Copy secrets/ ke root project, lalu jalankan:
#   bash switch-env.sh local

# =============================================
# DATABASE
# =============================================
DATABASE_URL=postgresql://servisgadget:[PASSWORD]@localhost:5432/servisgadget

# =============================================
# REDIS
# =============================================
REDIS_HOST=localhost
REDIS_PORT=6379

# =============================================
# JWT SECRETS (64-byte hex = 128 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
# =============================================
JWT_ACCESS_SECRET=[64-BYTE-HEX-1]
JWT_REFRESH_SECRET=[64-BYTE-HEX-2]
JWT_ACCESS_EXPIRES_IN=1h
JWT_REFRESH_EXPIRES_IN=30d

# JWT Store Admin — HARUS berbeda dari customer
JWT_STORE_ACCESS_SECRET=[64-BYTE-HEX-3]
JWT_STORE_REFRESH_SECRET=[64-BYTE-HEX-4]

# JWT Platform Admin — HARUS berbeda dari customer & store
JWT_PLATFORM_ADMIN_SECRET=[64-BYTE-HEX-5]

# =============================================
# CREDENTIAL ENCRYPTION (32-byte hex = 64 chars)
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# =============================================
CREDENTIAL_ENCRYPTION_KEY=[64-BYTE-HEX-KEY]

# =============================================
# WHATSAPP (Fonnte)
# =============================================
WA_GATEWAY_URL=https://api.fonnte.com/send
WA_GATEWAY_TOKEN=[YOUR-TOKEN]
WA_SENDER_NUMBER=628XXXXXXXXXX

# =============================================
# SMTP EMAIL
# =============================================
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=[YOUR-EMAIL]
SMTP_PASS=[YOUR-APP-PASSWORD]
SMTP_FROM=noreply@servisgadget.com
STORE_EMAIL=[NOTIF-EMAIL]

# =============================================
# STORAGE (Cloudflare R2 / S3)
# =============================================
STORAGE_ENDPOINT=https://[ACCOUNT-ID].r2.cloudflarestorage.com
STORAGE_ACCESS_KEY=[R2-ACCESS-KEY]
STORAGE_SECRET_KEY=[R2-SECRET-KEY]
STORAGE_BUCKET=servisgadget-prod
STORAGE_PUBLIC_URL=https://files.servisgadget.id

# =============================================
# APP
# =============================================
APP_URL=http://localhost:3000
NODE_ENV=development
PORT=3000

# =============================================
# SLA (menit)
# =============================================
SLA_RECEIVE_DEVICE_MINUTES=1440
SLA_DIAGNOSIS_MINUTES=1440
SLA_APPROVAL_MINUTES=1440
SLA_PAYMENT_MINUTES=2880
SLA_CREDENTIAL_CLEAR_MINUTES=1440
SLA_DISPUTE_RESPOND_MINUTES=1440

# =============================================
# RATE LIMIT
# =============================================
THROTTLE_TTL_SECONDS=60
THROTTLE_LIMIT=100

# =============================================
# MAINTENANCE
# =============================================
MAINTENANCE_MODE=false
MAINTENANCE_MESSAGE=Sedang dalam perbaikan

# =============================================
# CORS
# =============================================
CORS_ORIGIN=http://localhost:5173
CORS_CREDENTIALS=true

# =============================================
# CRON (untuk cron-sla endpoint)
# Set via Supabase Edge Function secrets:
#   supabase secrets set CRON_SECRET=<random string>
# =============================================
CRON_SECRET=[YOUR-CRON-SECRET]

# =============================================
# SEED (Platform Admin — wajib saat prisma seed)
# =============================================
SEED_PLATFORM_ADMIN_PASSWORD=[YOUR-SEED-PASSWORD]

# =============================================
# SUPABASE (Admin API — untuk sync guest account)
# Dapatkan dari: Project Settings → API → Service Role Key
# =============================================
SUPABASE_PROJECT_REF=[YOUR-PROJECT-REF]
SUPABASE_SERVICE_ROLE_KEY=[YOUR-SERVICE-ROLE-KEY]

# =============================================
# MIDTRANS (Sandbox)
# =============================================
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxx
MIDTRANS_MERCHANT_ID=Gxxxxxx
MIDTRANS_IS_PRODUCTION=false
